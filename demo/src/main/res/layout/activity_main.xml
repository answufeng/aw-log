<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            app:title="aw-log 控制台"
            app:subtitle="文件日志 · 脱敏拦截 · 崩溃收集 · 导出分析" />
    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <com.google.android.material.card.MaterialCardView
                style="@style/MaterialCardView.AwLog"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="运行配置"
                        style="@style/Text.AwLog.SectionTitle" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="开关配置会重新初始化 aw-log（用于演示不同组合）。"
                        style="@style/Text.AwLog.SectionSubtitle" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:orientation="vertical">

                        <com.google.android.material.materialswitch.MaterialSwitch
                            android:id="@+id/switchDebug"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Debug 输出（Logcat + 控制台）" />

                        <com.google.android.material.materialswitch.MaterialSwitch
                            android:id="@+id/switchFile"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="写入文件（滚动 + 压缩 + 导出）" />

                        <com.google.android.material.materialswitch.MaterialSwitch
                            android:id="@+id/switchCrash"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="崩溃收集（UncaughtException）" />

                        <com.google.android.material.materialswitch.MaterialSwitch
                            android:id="@+id/switchDesensitize"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="脱敏拦截（手机号/邮箱/kv）" />

                        <com.google.android.material.materialswitch.MaterialSwitch
                            android:id="@+id/switchCompact"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="文件日志：Compact 格式（HH:mm:ss.SSS）" />
                    </LinearLayout>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="最低输出级别"
                        style="@style/Text.AwLog.SectionSubtitle" />

                    <com.google.android.material.chip.ChipGroup
                        android:id="@+id/chipGroupMinLevel"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        app:singleSelection="true"
                        app:selectionRequired="true">

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chipMinVerbose"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="VERBOSE" />

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chipMinDebug"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="DEBUG" />

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chipMinInfo"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="INFO" />

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chipMinWarn"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="WARN" />

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chipMinError"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="ERROR" />
                    </com.google.android.material.chip.ChipGroup>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnApplyConfig"
                        style="@style/MaterialButton.AwLog.Filled"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="应用配置" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                style="@style/MaterialCardView.AwLog"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="实时控制台"
                            style="@style/Text.AwLog.SectionTitle" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnCopyLog"
                            style="@style/MaterialButton.AwLog.Outlined"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="复制" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnShareLog"
                            style="@style/MaterialButton.AwLog.Outlined"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            android:text="分享" />
                    </LinearLayout>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="用于演示 AwLogListener 的实时回调（颜色区分级别）。"
                        style="@style/Text.AwLog.SectionSubtitle" />

                    <ScrollView
                        android:id="@+id/logScrollView"
                        android:layout_width="match_parent"
                        android:layout_height="220dp"
                        android:layout_marginTop="12dp"
                        android:background="@color/log_background"
                        android:padding="12dp">

                        <TextView
                            android:id="@+id/tvLog"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            style="@style/Text.AwLog.Log"
                            android:text="" />
                    </ScrollView>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:orientation="horizontal">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnClearLog"
                            style="@style/MaterialButton.AwLog.Outlined"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="清空控制台" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnFlush"
                            style="@style/MaterialButton.AwLog.Outlined"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            android:layout_weight="1"
                            android:text="Flush 到磁盘" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                style="@style/MaterialCardView.AwLog"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="快速打点"
                        style="@style/Text.AwLog.SectionTitle" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:orientation="horizontal">

                        <com.google.android.material.textfield.TextInputLayout
                            android:id="@+id/tilTag"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:hint="Tag (可选)">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/etTag"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:singleLine="true" />
                        </com.google.android.material.textfield.TextInputLayout>

                        <com.google.android.material.textfield.TextInputLayout
                            android:id="@+id/tilMessage"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="12dp"
                            android:layout_weight="2"
                            android:hint="Message">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/etMessage"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:singleLine="true" />
                        </com.google.android.material.textfield.TextInputLayout>
                    </LinearLayout>

                    <com.google.android.material.chip.ChipGroup
                        android:id="@+id/chipGroupSendLevel"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        app:singleSelection="true"
                        app:selectionRequired="true">

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chipSendDebug"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="DEBUG" />

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chipSendInfo"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="INFO" />

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chipSendWarn"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="WARN" />

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chipSendError"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="ERROR" />
                    </com.google.android.material.chip.ChipGroup>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:orientation="horizontal">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnSend"
                            style="@style/MaterialButton.AwLog.Filled"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="发送日志" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnSendThrowable"
                            style="@style/MaterialButton.AwLog.Outlined"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            android:layout_weight="1"
                            android:text="带异常" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:orientation="horizontal">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnJson"
                            style="@style/MaterialButton.AwLog.Outlined"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="JSON" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnXml"
                            style="@style/MaterialButton.AwLog.Outlined"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            android:layout_weight="1"
                            android:text="XML" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnDesensitize"
                            style="@style/MaterialButton.AwLog.Outlined"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            android:layout_weight="1"
                            android:text="脱敏样例" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                style="@style/MaterialCardView.AwLog"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="文件与导出"
                        style="@style/Text.AwLog.SectionTitle" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:orientation="horizontal">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnFileInfo"
                            style="@style/MaterialButton.AwLog.Outlined"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="文件信息" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnCompress"
                            style="@style/MaterialButton.AwLog.Outlined"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            android:layout_weight="1"
                            android:text="压缩旧文件" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:orientation="horizontal">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnExport"
                            style="@style/MaterialButton.AwLog.Filled"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="导出 ZIP" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnClearLogs"
                            style="@style/MaterialButton.AwLog.Outlined"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            android:layout_weight="1"
                            android:text="清除文件" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                style="@style/MaterialCardView.AwLog"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="压力与崩溃演示"
                        style="@style/Text.AwLog.SectionTitle" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:orientation="horizontal">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnConcurrent"
                            style="@style/MaterialButton.AwLog.Outlined"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="并发写入" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnCrash"
                            style="@style/MaterialButton.AwLog.Filled"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            android:layout_weight="1"
                            android:text="触发崩溃" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</androidx.coordinatorlayout.widget.CoordinatorLayout>
