<resources>
    <style name="Theme.AwLogdemo" parent="Theme.Material3.Light.NoActionBar">
        <item name="colorPrimary">@color/colorPrimary</item>
        <item name="colorPrimaryDark">@color/colorPrimaryDark</item>
        <item name="colorAccent">@color/colorAccent</item>
    </style>

    <style name="Text.AwLog.Subtitle" parent="TextAppearance.Material3.TitleSmall">
        <item name="android:textColor">@color/colorPrimary</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="Text.AwLog.Log" parent="TextAppearance.Material3.BodySmall">
        <item name="android:textColor">@color/log_debug</item>
        <item name="android:fontFamily">monospace</item>
    </style>

    <style name="MaterialButton.AwLog.Outlined" parent="Widget.Material3.Button.OutlinedButton">
        <item name="android:textSize">12sp</item>
        <item name="android:minHeight">40dp</item>
    </style>
</resources>
