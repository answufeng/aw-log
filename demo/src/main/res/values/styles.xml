<resources>
    <style name="Theme.AwLogdemo" parent="Theme.Material3.Light.NoActionBar">
        <item name="colorPrimary">@color/colorPrimary</item>
        <item name="colorSecondary">@color/colorSecondary</item>
        <item name="colorTertiary">@color/colorAccent</item>
        <item name="android:colorBackground">@color/background</item>
        <item name="colorSurface">@color/surface</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="colorOnBackground">@color/text_primary</item>
    </style>

    <style name="Text.AwLog.SectionTitle" parent="TextAppearance.Material3.TitleMedium">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="Text.AwLog.SectionSubtitle" parent="TextAppearance.Material3.BodyMedium">
        <item name="android:textColor">@color/text_muted</item>
    </style>

    <style name="Text.AwLog.Log" parent="TextAppearance.Material3.BodySmall">
        <item name="android:textColor">@color/log_verbose</item>
        <item name="android:fontFamily">monospace</item>
        <item name="android:lineSpacingExtra">2dp</item>
    </style>

    <style name="MaterialButton.AwLog.Outlined" parent="Widget.Material3.Button.OutlinedButton">
        <item name="android:minHeight">40dp</item>
        <item name="android:textAllCaps">false</item>
    </style>

    <style name="MaterialButton.AwLog.Filled" parent="Widget.Material3.Button">
        <item name="android:minHeight">44dp</item>
        <item name="android:textAllCaps">false</item>
    </style>

    <style name="MaterialCardView.AwLog" parent="Widget.Material3.CardView.Elevated">
        <item name="cardUseCompatPadding">true</item>
    </style>
</resources>
